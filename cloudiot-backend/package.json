{
  "name": "cloudiot-backend",
  "version": "1.0.0",
  "description": "Cloudflare Workers IoT Backend",
  "main": "src/index.ts",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "db:create": "wrangler d1 create cloudiot-db",
    "db:migrate": "wrangler d1 execute cloudiot-db --file=migrations/001_initial_schema.sql",
    "db:dev": "wrangler d1 execute cloudiot-db-dev --local --file=migrations/001_initial_schema.sql"
  },
  "dependencies": {
    "@cloudflare/workers-types": "^4.20241127.0",
    "itty-router": "^5.0.17",
    "jose": "^5.9.6"
  },
  "devDependencies": {
    "wrangler": "^3.93.0",
    "typescript": "^5.7.2"
  }
}
